PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/bizrunner
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Etsy
ETSY_CLIENT_ID=your_etsy_client_id
ETSY_CLIENT_SECRET=your_etsy_client_secret
ETSY_REDIRECT_URI=http://localhost:3000/api/auth/etsy/callback

# Meta (Instagram/Facebook)
META_CLIENT_ID=your_meta_client_id
META_CLIENT_SECRET=your_meta_client_secret
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# AI
OPENAI_API_KEY=your_openai_api_key
